# Server-only secrets (never use PUBLIC_ prefix for API keys)
# Copy to .env.local for local dev.

# Arc Raiders API
ARC_API_BASE_URL=https://arcraidersapi.com
ARC_API_KEY=arc_live_replace_me
PUBLIC_API_PROXY_URL=https://arcraided-api-proxy.<your-subdomain>.workers.dev

# Optional: app-level controls
API_DEFAULT_LIMIT=100
API_REQUEST_TIMEOUT_MS=10000

