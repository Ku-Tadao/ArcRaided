---
import Layout from '@/layouts/Layout.astro';
import Overview from '@/components/Overview.astro';
import Items from '@/components/Items.astro';
import Enemies from '@/components/Enemies.astro';
import Quests from '@/components/Quests.astro';
import Traders from '@/components/Traders.astro';
import Maps from '@/components/Maps.astro';
import SkillTree from '@/components/SkillTree.astro';
import EventTimers from '@/components/EventTimers.astro';
import Guides from '@/components/Guides.astro';
import Marketplace from '@/components/Marketplace.astro';
import LootTiers from '@/components/LootTiers.astro';
import NeededItems from '@/components/NeededItems.astro';
import BlueprintTracker from '@/components/BlueprintTracker.astro';
import WorkshopPlanner from '@/components/WorkshopPlanner.astro';
import Loadouts from '@/components/Loadouts.astro';
import TierLists from '@/components/TierLists.astro';
import WeeklyTrials from '@/components/WeeklyTrials.astro';
import { fetchAllData } from '@/lib/api';

const data = await fetchAllData();

const buildDate = new Date(data.buildInfo.generatedAt).toLocaleString('en-US', {
    dateStyle: 'medium',
    timeStyle: 'short',
});

const clientPayload = JSON.stringify({
    items: data.items.map(i => ({ id: i.id, name: i.name, type: i.type, rarity: i.rarity, category: i.category, description: i.description, value: i.value, icon: i.icon, foundIn: i.foundIn })),
    enemies: data.enemies.map(e => ({ id: e.id, name: e.name, description: e.description, icon: e.icon, image: e.image, dropTable: e.dropTable, relatedMaps: e.relatedMaps })),
    quests: data.quests.map(q => ({ id: q.id, title: q.title, description: q.description, trader: q.trader, maps: q.maps, steps: q.steps, requiredItems: q.requiredItems, xpReward: q.xpReward })),
    buildInfo: data.buildInfo,
    metaforge: {
        items: data.metaforge.items.map(i => ({ id: i.id, name: i.name, type: i.item_type, rarity: i.rarity, category: i.category, description: i.description, value: i.value, icon: i.icon, stat_block: i.stat_block, trader_price: i.trader_price, ammo_type: i.ammo_type, loadout_slots: i.loadout_slots, shield_type: i.shield_type })),
        quests: data.metaforge.quests.map(q => ({ id: q.id, title: q.name, objectives: q.objectives, xp: q.xp, trader_name: q.trader_name, image: q.image, rewards: q.rewards, guide_links: q.guide_links })),
    },
    skills: data.skills,
    arcTraders: data.arcTraders,
    events: data.events.map(e => ({ name: e.name, map: e.map, icon: e.icon, startTime: e.startTime, endTime: e.endTime })),
});
---

<Layout buildDate={buildDate}>
    <div id="app-data" data-payload={clientPayload} style="display:none"></div>

    <Overview items={data.items} enemies={data.enemies} quests={data.quests} maps={data.maps} traders={data.traders} />
    <Items items={data.items} />
    <Enemies enemies={data.enemies} />
    <Quests quests={data.quests} traders={data.traders} maps={data.maps} />
    <Traders arcTraders={data.arcTraders} mfTraders={data.mfTraders} quests={data.quests} />
    <Maps arcMaps={data.arcMaps} questMaps={data.maps} quests={data.quests} enemies={data.enemies} />
    <SkillTree skills={data.skills} />
    <EventTimers events={data.events} />
    <Guides quests={data.metaforge.quests} />
    <Marketplace items={data.items} />
    <LootTiers items={data.items} />
    <NeededItems items={data.items} />
    <BlueprintTracker items={data.items} />
    <WorkshopPlanner items={data.metaforge.items} />
    <Loadouts items={data.metaforge.items} />
    <TierLists items={data.items} />
    <WeeklyTrials trials={data.weeklyTrials} />

    <script>
        import '../scripts/app.ts';
    </script>
</Layout>
