---
import '@/styles/global.css';
import { SVG_ICONS } from '@/lib/icons';

interface Props {
  title?: string;
  description?: string;
  buildDate?: string;
}

const {
    title = 'ArcRaided — Arc Raiders Data Hub',
    description = 'Explore Arc Raiders items, enemies, quests, and traders. All data sourced from community APIs.',
    buildDate = new Date().toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }),
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Saira:wght@500;600;700;800&display=swap" rel="stylesheet">
    <script is:inline>if(location.hash)history.replaceState(null,'',location.pathname+location.search);if('scrollRestoration'in history)history.scrollRestoration='manual';</script>
</head>
<body>
    <header>
        <div class="container">
            <div class="header-bar">
                <div class="header-brand">
                    <h1>ArcRaided</h1>
                    <span class="version-pill">Arc Raiders</span>
                </div>
                <div class="header-actions">
                    <button id="themeToggle" class="btn btn-ghost btn-sm" type="button">Dark Mode</button>
                </div>
            </div>
        </div>
    </header>

    <nav>
        <div class="container nav-wrap">
            <div class="nav-inner">
                <button class="nav-link active" data-section="overview" type="button">Home</button>

                <div class="nav-dropdown">
                    <button class="nav-link nav-dropdown-trigger" type="button">Database ▾</button>
                    <div class="nav-dropdown-menu hidden">
                        <button class="nav-dd-item" data-section="items" type="button"><span class="nav-dd-icon">📦</span> Items</button>
                        <button class="nav-dd-item" data-section="enemies" data-source-only="ardb" type="button"><span class="nav-dd-icon">🎯</span> ARCs</button>
                        <button class="nav-dd-item" data-section="quests" type="button"><span class="nav-dd-icon">📜</span> Quests</button>
                        <button class="nav-dd-item" data-section="traders" type="button"><span class="nav-dd-icon">👥</span> Traders</button>
                        <button class="nav-dd-item" data-section="maps" data-source-only="ardb" type="button"><span class="nav-dd-icon">🗺️</span> Maps</button>
                    </div>
                </div>

                <div class="nav-dropdown">
                    <button class="nav-link nav-dropdown-trigger" type="button">Tools ▾</button>
                    <div class="nav-dropdown-menu hidden">
                        <button class="nav-dd-item" data-section="marketplace" data-source-only="ardb" type="button"><span class="nav-dd-icon">🏪</span> Marketplace</button>
                        <button class="nav-dd-item" data-section="loot-tiers" data-source-only="ardb" type="button"><span class="nav-dd-icon">💎</span> Loot Value Tiers</button>
                        <button class="nav-dd-item" data-section="needed-items" type="button"><span class="nav-dd-icon">✅</span> Needed Items</button>
                        <button class="nav-dd-item" data-section="blueprints" type="button"><span class="nav-dd-icon">📋</span> Blueprint Tracker</button>
                        <button class="nav-dd-item" data-section="workshop" data-source-only="metaforge" type="button"><span class="nav-dd-icon">🔧</span> Workshop Planner</button>
                        <button class="nav-dd-item" data-section="loadouts" data-source-only="metaforge" type="button"><span class="nav-dd-icon">🎒</span> Loadouts</button>
                        <button class="nav-dd-item" data-section="tier-lists" type="button"><span class="nav-dd-icon">📊</span> Tier Lists</button>
                    </div>
                </div>

                <button class="nav-link" data-section="skills" data-source-only="metaforge" type="button">Skill Tree</button>
                <button class="nav-link" data-section="guides" data-source-only="metaforge" type="button">Guides</button>
                <button class="nav-link" data-section="events" data-source-only="metaforge" type="button">Events</button>
                <button class="nav-link" data-section="weekly-trials" data-source-only="metaforge" type="button">Weekly Trials</button>
            </div>
            <div class="nav-right">
                <div class="source-toggle" id="sourceToggle">
                    <button class="source-btn active" data-source="ardb" type="button" title="ARDB — 483 items, 84 quests">
                        <span class="source-dot ardb"></span>ARDB
                    </button>
                    <button class="source-btn" data-source="metaforge" type="button" title="MetaForge — 50 items, 40 quests, stat blocks">
                        <span class="source-dot metaforge"></span>MetaForge
                    </button>
                </div>
                <div class="product-switcher">
                <button class="product-switcher-btn" type="button" id="productSwitcherBtn">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1" fill="currentColor" opacity=".5"/><rect x="1" y="9" width="6" height="6" rx="1" fill="currentColor" opacity=".5"/><rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor" opacity=".3"/></svg>
                    Apps
                </button>
                <div class="product-switcher-dropdown hidden" id="productSwitcherDropdown">
                    <div class="product-dropdown-label">Switch App</div>
                    <a href="https://ku-tadao.github.io/LockedIn/" class="product-card">
                        <img class="product-card-img" src="https://cdn.akamai.steamstatic.com/steam/apps/1422450/header.jpg" alt="Deadlock" loading="lazy" />
                        <div class="product-card-info">
                            <strong>LockedIn</strong>
                            <span>Deadlock Data Hub</span>
                        </div>
                    </a>
                    <a href="https://ku-tadao.github.io/OverWatched/" class="product-card">
                        <img class="product-card-img" src="https://cdn.akamai.steamstatic.com/steam/apps/2357570/header.jpg" alt="Overwatch 2" loading="lazy" />
                        <div class="product-card-info">
                            <strong>OverWatched</strong>
                            <span>Overwatch Data Hub</span>
                        </div>
                    </a>
                    <a href="https://ku-tadao.github.io/Scouted/" class="product-card">
                        <img class="product-card-img" src="https://cmsassets.rgpub.io/sanity/images/dsfx7636/news_live/d63adacd93e313c1e61bbeb2eb37d8c4ca85848d-1920x1080.jpg" alt="TFT" loading="lazy" />
                        <div class="product-card-info">
                            <strong>Scouted</strong>
                            <span>TFT Data Hub</span>
                        </div>
                    </a>
                    <a href="https://ku-tadao.github.io/ArcRaided/" class="product-card active">
                        <img class="product-card-img" src="https://cdn.akamai.steamstatic.com/steam/apps/1304350/header.jpg" alt="Arc Raiders" loading="lazy" />
                        <div class="product-card-info">
                            <strong>ArcRaided</strong>
                            <span>Arc Raiders Data Hub</span>
                        </div>
                    </a>
                </div>
            </div>
            </div>
        </div>
    </nav>

    <main class="container">
        <slot />
    </main>

    <!-- Item Detail Modal -->
    <div id="itemModal" class="modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-content" role="document">
            <div id="modalItemDetails"></div>
            <button type="button" id="closeItemModalBtn" class="btn btn-brand" style="margin-top:1rem">Close</button>
        </div>
    </div>

    <!-- Enemy Detail Modal -->
    <div id="enemyModal" class="modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-content" role="document">
            <div id="modalEnemyDetails"></div>
            <button type="button" id="closeEnemyModalBtn" class="btn btn-brand" style="margin-top:1rem">Close</button>
        </div>
    </div>

    <!-- Quest Detail Modal -->
    <div id="questModal" class="modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-content" role="document">
            <div id="modalQuestDetails"></div>
            <button type="button" id="closeQuestModalBtn" class="btn btn-brand" style="margin-top:1rem">Close</button>
        </div>
    </div>

    <!-- Trader Detail Modal -->
    <div id="traderModal" class="modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-content" role="document">
            <div id="modalTraderDetails"></div>
            <button type="button" id="closeTraderModalBtn" class="btn btn-brand" style="margin-top:1rem">Close</button>
        </div>
    </div>

    <!-- Skill Detail Modal -->
    <div id="skillModal" class="modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-content" role="document">
            <div id="modalSkillDetails"></div>
            <button type="button" id="closeSkillModalBtn" class="btn btn-brand" style="margin-top:1rem">Close</button>
        </div>
    </div>

    <!-- Item Picker Modal (for Loadouts & Workshop) -->
    <div id="loadoutPickerModal" class="modal hidden" role="dialog" aria-modal="true">
        <div class="modal-content" role="document">
            <div class="section-header" style="margin-bottom:1rem">
                <h3 style="margin:0">Choose Item</h3>
                <div class="search-filter">
                    <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
                    <input type="text" id="loadoutPickerSearch" placeholder="Search items..." />
                </div>
            </div>
            <div class="items-grid" id="loadoutPickerGrid"></div>
            <button type="button" id="closeLoadoutPicker" class="btn btn-ghost" style="margin-top:1rem">Cancel</button>
        </div>
    </div>

    <footer>
        <div class="container">
            <p>ArcRaided &middot; Built {buildDate} &middot; Data: <a href="https://ardb.app" target="_blank" rel="noopener noreferrer" class="stealth-link">ARDB</a> + <a href="https://metaforge.app/arc-raiders" target="_blank" rel="noopener noreferrer" class="stealth-link">MetaForge</a></p>
            <p class="footer-disclaimer">ArcRaided is not affiliated with or endorsed by Embark Studios.</p>
        </div>
    </footer>
</body>
</html>
