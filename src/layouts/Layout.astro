---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
    title = 'ArcRaided — Arc Raiders Data Hub',
    description = 'Explore Arc Raiders items, enemies, quests, and traders. All data sourced from community APIs.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Saira:wght@500;600;700;800&display=swap" rel="stylesheet">
    <script is:inline>if(location.hash)history.replaceState(null,'',location.pathname+location.search);if('scrollRestoration'in history)history.scrollRestoration='manual';</script>
</head>
<body>
    <header>
        <div class="container">
            <div class="header-bar">
                <div class="header-brand">
                    <h1>ArcRaided</h1>
                    <span class="version-pill">Arc Raiders</span>
                </div>
                <div class="header-actions">
                    <button class="btn btn-ghost btn-sm" id="themeToggle" type="button">Dark Mode</button>
                </div>
            </div>
        </div>
    </header>

    <nav>
        <div class="container">
            <div class="nav-wrap">
                <div class="nav-inner">
                    <button class="nav-link active" data-section="overview" type="button">Overview</button>
                    <button class="nav-link" data-section="items" type="button">Items</button>
                    <button class="nav-link" data-section="enemies" type="button">Enemies</button>
                    <button class="nav-link" data-section="quests" type="button">Quests</button>
                </div>

                <!-- Product Switcher -->
                <div class="product-switcher">
                    <button class="product-switcher-btn" id="productSwitcherBtn" type="button">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        Apps
                    </button>
                    <div class="product-switcher-dropdown hidden" id="productDropdown">
                        <div class="product-dropdown-label">Ku-Tadao Products</div>
                        <a class="product-card" href="https://ku-tadao.github.io/LockedIn/">
                            <div class="product-card-info">
                                <strong>LockedIn</strong>
                                <span>Deadlock Hero Hub</span>
                            </div>
                        </a>
                        <a class="product-card" href="https://ku-tadao.github.io/OverWatched/">
                            <div class="product-card-info">
                                <strong>OverWatched</strong>
                                <span>Overwatch 2 Tracker</span>
                            </div>
                        </a>
                        <a class="product-card" href="https://ku-tadao.github.io/Scouted/">
                            <div class="product-card-info">
                                <strong>Scouted</strong>
                                <span>TFT Data Explorer</span>
                            </div>
                        </a>
                        <a class="product-card active" href={`${base}/`}>
                            <div class="product-card-info">
                                <strong>ArcRaided</strong>
                                <span>Arc Raiders Data Hub</span>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="container">
        <slot />
    </main>

    <!-- Item Detail Modal -->
    <div class="modal hidden" id="itemModal" role="dialog" aria-hidden="true">
        <div class="modal-content">
            <button class="modal-close" id="itemModalClose" type="button" aria-label="Close">&times;</button>
            <div id="modalItemDetails"></div>
        </div>
    </div>

    <!-- Enemy Detail Modal -->
    <div class="modal hidden" id="enemyModal" role="dialog" aria-hidden="true">
        <div class="modal-content">
            <button class="modal-close" id="enemyModalClose" type="button" aria-label="Close">&times;</button>
            <div id="modalEnemyDetails"></div>
        </div>
    </div>

    <!-- Quest Detail Modal -->
    <div class="modal hidden" id="questModal" role="dialog" aria-hidden="true">
        <div class="modal-content">
            <button class="modal-close" id="questModalClose" type="button" aria-label="Close">&times;</button>
            <div id="modalQuestDetails"></div>
        </div>
    </div>

    <footer>
        <div class="container">
            <p>
                ArcRaided &middot; Data sources:
                <a href="https://arcraidersapi.com" target="_blank" rel="noopener noreferrer" class="stealth-link">ArcRaiders API</a>,
                <a href="https://metaforge.app/arc-raiders" target="_blank" rel="noopener noreferrer" class="stealth-link">MetaForge</a>,
                <a href="https://ardb.app" target="_blank" rel="noopener noreferrer" class="stealth-link">ARDB</a>
            </p>
            <p class="footer-disclaimer">
                Data provided by <a href="https://ardb.app" target="_blank" rel="noopener noreferrer" class="stealth-link">ardb.app</a>.
                MetaForge attribution per source requirements.
            </p>
            <p class="footer-disclaimer">
                ArcRaided is not affiliated with or endorsed by Embark Studios.
            </p>
        </div>
    </footer>

    <script is:inline src={`${base}/scripts/app.js`}></script>
</body>
</html>
