---
import { SVG_ICONS } from '@/lib/icons';
import type { ArcTrader, MetaForgeTrader, ArdbQuest } from '@/lib/types';
import { ARDB_BASE } from '@/lib/types';

interface Props {
    arcTraders: ArcTrader[];
    mfTraders: MetaForgeTrader[];
    quests: ArdbQuest[];
}

const { arcTraders, mfTraders, quests } = Astro.props;

function resolveImg(path: string | undefined): string {
    if (!path) return '';
    if (path.startsWith('http')) return path;
    return `${ARDB_BASE}${path}`;
}

// Merge traders from all sources
interface MergedTrader {
    id: string;
    name: string;
    description: string;
    image: string;
    icon: string;
    type: string;
    questCount: number;
    source: string;
}

const traderMap = new Map<string, MergedTrader>();

// From Arc API traders
for (const t of arcTraders) {
    const questCount = quests.filter(q => q.trader?.id === t.id || q.trader?.name === t.name).length;
    traderMap.set(t.id, {
        id: t.id,
        name: t.name,
        description: (t.description as string) ?? '',
        image: resolveImg(t.image as string),
        icon: resolveImg(t.icon as string),
        type: (t.type as string) ?? '',
        questCount,
        source: 'arc',
    });
}

// From quest data (fallback)
for (const q of quests) {
    if (q.trader && !traderMap.has(q.trader.id)) {
        const questCount = quests.filter(qq => qq.trader?.id === q.trader.id).length;
        traderMap.set(q.trader.id, {
            id: q.trader.id,
            name: q.trader.name,
            description: q.trader.description ?? '',
            image: resolveImg(q.trader.image),
            icon: resolveImg(q.trader.icon),
            type: q.trader.type ?? '',
            questCount,
            source: 'ardb',
        });
    }
}

// From MetaForge traders
for (const t of mfTraders) {
    if (!traderMap.has(t.id)) {
        traderMap.set(t.id, {
            id: t.id,
            name: t.name,
            description: (t.description as string) ?? '',
            image: (t.image as string) ?? '',
            icon: (t.icon as string) ?? '',
            type: (t.type as string) ?? '',
            questCount: 0,
            source: 'metaforge',
        });
    }
}

const allTraders = [...traderMap.values()].sort((a, b) => b.questCount - a.questCount);
---

<section id="traders" class="content" style="display:none">
    <div class="section-header">
        <h2>Traders</h2>
        <div class="search-filter">
            <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
            <input type="text" id="traderSearch" placeholder="Search traders..." />
        </div>
    </div>

    {allTraders.length === 0 ? (
        <p class="no-results">No trader data available.</p>
    ) : (
        <div class="traders-grid" id="traderGrid">
            {allTraders.map((trader) => (
                <div class="trader-card" data-id={trader.id} data-name={trader.name.toLowerCase()}>
                    <div class="trader-card-portrait">
                        {trader.image || trader.icon ? (
                            <img
                                src={trader.image || trader.icon}
                                alt={trader.name}
                                loading="lazy"
                            />
                        ) : (
                            <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;opacity:0.3">
                                <Fragment set:html={SVG_ICONS.users} />
                            </div>
                        )}
                    </div>
                    <div class="trader-card-info">
                        <div class="trader-card-name">{trader.name}</div>
                        {trader.type && <div class="trader-card-type">{trader.type}</div>}
                        <div class="trader-card-meta">
                            {trader.questCount > 0 && (
                                <span class="reward-chip">{trader.questCount} quests</span>
                            )}
                        </div>
                    </div>
                    {trader.description && (
                        <p class="trader-card-desc">{trader.description}</p>
                    )}
                </div>
            ))}
        </div>
    )}

    <p class="no-results hidden" id="noTraderResults">No traders match your search.</p>
</section>
