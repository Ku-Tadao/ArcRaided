---
/**
 * Loot Value Tiers — groups items into value brackets
 */
import { SVG_ICONS, getWeaponIconSVG } from '@/lib/icons';
import type { ArdbItem } from '@/lib/types';
import { ARDB_BASE } from '@/lib/types';

interface Props {
    items: ArdbItem[];
}

const { items } = Astro.props;

// Define value tiers
const tiers = [
    { name: 'S-Tier', label: 'S', min: 10000, color: 'var(--rarity-legendary)', bg: 'var(--rarity-legendary-bg)' },
    { name: 'A-Tier', label: 'A', min: 5000, color: 'var(--rarity-epic)', bg: 'var(--rarity-epic-bg)' },
    { name: 'B-Tier', label: 'B', min: 2000, color: 'var(--rarity-rare)', bg: 'var(--rarity-rare-bg)' },
    { name: 'C-Tier', label: 'C', min: 500, color: 'var(--rarity-uncommon)', bg: 'var(--rarity-uncommon-bg)' },
    { name: 'D-Tier', label: 'D', min: 0, color: 'var(--rarity-common)', bg: 'var(--rarity-common-bg)' },
];

const tierGroups = tiers.map(tier => {
    const nextTier = tiers[tiers.indexOf(tier) - 1];
    const tierItems = items.filter(i => {
        const v = i.value ?? 0;
        if (nextTier) return v >= tier.min && v < nextTier.min;
        return v >= tier.min;
    }).sort((a, b) => b.value - a.value);
    return { ...tier, items: tierItems };
});
---

<section id="loot-tiers" class="content" data-source-only="ardb" style="display:none">
    <div class="section-header">
        <h2>Loot Value Tiers</h2>
    </div>

    <p class="muted" style="margin-bottom:1.5rem">Items grouped by their sell value. Higher tier = more valuable loot to prioritize.</p>

    <div class="tier-groups" id="tierGroupsContainer">
        {tierGroups.map((group) => (
            <div class="tier-group" style={`--tier-color: ${group.color}; --tier-bg: ${group.bg}`}>
                <div class="tier-header">
                    <span class="tier-badge" style={`background: ${group.bg}; color: ${group.color}; border: 1px solid ${group.color}`}>
                        {group.label}
                    </span>
                    <span class="tier-name">{group.name}</span>
                    <span class="tier-range">
                        {group.min.toLocaleString()}+
                    </span>
                    <span class="count">{group.items.length} items</span>
                </div>
                {group.items.length > 0 ? (
                    <div class="tier-items">
                        {group.items.map((item, index) => (
                            <div class={`item-card rarity-${item.rarity ?? 'common'}`} data-id={item.id} style={index >= 20 ? "display: none;" : null}>
                                <div class="rarity-image-wrap item-card-image-wrap">
                                    <div class="rarity-curve"></div>
                                    {item.icon ? (
                                        <img src={`${ARDB_BASE}${item.icon}`} alt={item.name} loading="lazy" class="item-img" />
                                    ) : (
                                        <div style="display:flex;align-items:center;justify-content:center;opacity:0.3;width:100%;height:100%">
                                            <Fragment set:html={SVG_ICONS.package} />
                                        </div>
                                    )}
                                    <div class="item-value-badge">{item.value?.toLocaleString()}</div>
                                </div>
                                <div class="item-card-footer">
                                    <span class="item-type-icon">
                                        <Fragment set:html={getWeaponIconSVG(item.name)} />
                                    </span>
                                    <span class="item-card-name">{item.name}</span>
                                </div>
                            </div>
                        ))}
                        {group.items.length > 20 && (
                            <button class="btn show-more-tier-btn" style="grid-column: 1 / -1; margin-top: .5rem; font-size: .8rem; padding: .5rem; background: var(--surface-2); color: var(--text-2); border: 1px solid var(--border); border-radius: var(--radius); cursor: pointer;">+{group.items.length - 20} more items</button>
                        )}
                    </div>
                ) : (
                    <p class="muted" style="padding:.75rem;font-size:.85rem">No items in this tier.</p>
                )}
            </div>
        ))}
    </div>
</section>

