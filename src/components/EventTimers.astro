---
import { SVG_ICONS } from '@/lib/icons';
import type { MetaForgeEvent } from '@/lib/types';

interface Props {
    events: MetaForgeEvent[];
}

const { events } = Astro.props;

const nowMs = Date.now();

// Group events by name and aggregate maps + instances
interface EventGroup {
    name: string;
    icon: string;
    maps: string[];
    instances: { map: string; startTime: number; endTime: number }[];
    activeInstance: { map: string; endTime: number } | null;
    nextInstance: { map: string; startTime: number } | null;
    status: 'active' | 'upcoming' | 'not-in-rotation';
}

const groupMap = new Map<string, EventGroup>();

for (const ev of events) {
    let group = groupMap.get(ev.name);
    if (!group) {
        group = { name: ev.name, icon: ev.icon, maps: [], instances: [], activeInstance: null, nextInstance: null, status: 'not-in-rotation' };
        groupMap.set(ev.name, group);
    }
    if (!group.maps.includes(ev.map)) group.maps.push(ev.map);
    group.instances.push({ map: ev.map, startTime: ev.startTime, endTime: ev.endTime });
}

// Determine status for each group
for (const group of groupMap.values()) {
    group.instances.sort((a, b) => a.startTime - b.startTime);
    const active = group.instances.find(i => nowMs >= i.startTime && nowMs < i.endTime);
    if (active) {
        group.status = 'active';
        group.activeInstance = { map: active.map, endTime: active.endTime };
    } else {
        const upcoming = group.instances.find(i => i.startTime > nowMs);
        if (upcoming) {
            group.status = 'upcoming';
            group.nextInstance = { map: upcoming.map, startTime: upcoming.startTime };
        }
    }
}

const allGroups = [...groupMap.values()];
const activeEvents = allGroups.filter(g => g.status === 'active');
const upcomingEvents = allGroups.filter(g => g.status === 'upcoming').sort((a, b) => (a.nextInstance?.startTime ?? 0) - (b.nextInstance?.startTime ?? 0));
const notInRotation = allGroups.filter(g => g.status === 'not-in-rotation');

function formatTime(ms: number): string {
    try { return new Date(ms).toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', month: 'short', day: 'numeric' }); }
    catch { return '—'; }
}
function formatTimeShort(ms: number): string {
    try { return new Date(ms).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }); }
    catch { return '—'; }
}
---

<section id="events" class="content" style="display:none">
    <div class="section-header">
        <h2>Event Timers</h2>
        <span class="badge">{events.length} instances · {allGroups.length} events</span>
    </div>

    {allGroups.length === 0 ? (
        <div class="empty-state">
            <Fragment set:html={SVG_ICONS.clock} />
            <p>No event data available. Check back later.</p>
        </div>
    ) : (
        <Fragment>
            {activeEvents.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title active-title">Active now</h3>
                    <div class="events-list" id="eventListActive">
                        {activeEvents.map(group => (
                            <div class="event-card event-active" data-name={group.name}>
                                <div class="event-card-top">
                                    <img src={group.icon} alt={group.name} class="event-card-icon" loading="lazy" />
                                    <div>
                                        <div class="event-card-name">{group.name}</div>
                                        <div class="event-card-map">{group.activeInstance!.map}</div>
                                    </div>
                                    <span class="event-status-badge active">Active</span>
                                </div>
                                <div class="event-countdown" data-end-ms={group.activeInstance!.endTime.toString()}>
                                    <span class="countdown-label">Ends in</span>
                                    <span class="countdown-timer" data-end-ms={group.activeInstance!.endTime.toString()}>calculating...</span>
                                </div>
                                {group.instances.length > 1 && (
                                    <details class="event-instances">
                                        <summary>Upcoming instances ({group.instances.filter(i => i.startTime > nowMs).length})</summary>
                                        <ul>
                                            {group.instances.filter(i => i.startTime > nowMs).slice(0, 5).map(i => (
                                                <li>{formatTimeShort(i.startTime)} – {formatTimeShort(i.endTime)} <span class="event-inst-map">{i.map}</span></li>
                                            ))}
                                        </ul>
                                    </details>
                                )}
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}

            {upcomingEvents.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title upcoming-title">Upcoming next</h3>
                    <div class="events-list" id="eventListUpcoming">
                        {upcomingEvents.map(group => (
                            <div class="event-card event-upcoming" data-name={group.name}>
                                <div class="event-card-top">
                                    <img src={group.icon} alt={group.name} class="event-card-icon" loading="lazy" />
                                    <div>
                                        <div class="event-card-name">{group.name}</div>
                                        <div class="event-card-map">{group.maps.join(', ')}</div>
                                    </div>
                                    <span class="event-status-badge upcoming">Upcoming</span>
                                </div>
                                <div class="event-countdown" data-start-ms={group.nextInstance!.startTime.toString()}>
                                    <span class="countdown-label">Starts in</span>
                                    <span class="countdown-timer" data-start-ms={group.nextInstance!.startTime.toString()}>calculating...</span>
                                </div>
                                <div class="event-card-times">
                                    <span class="event-time"><Fragment set:html={SVG_ICONS.clock} /> {formatTime(group.nextInstance!.startTime)} on {group.nextInstance!.map}</span>
                                </div>
                                {group.instances.length > 1 && (
                                    <details class="event-instances">
                                        <summary>Upcoming instances ({group.instances.filter(i => i.startTime > nowMs).length})</summary>
                                        <ul>
                                            {group.instances.filter(i => i.startTime > nowMs).slice(0, 5).map(i => (
                                                <li>{formatTimeShort(i.startTime)} – {formatTimeShort(i.endTime)} <span class="event-inst-map">{i.map}</span></li>
                                            ))}
                                        </ul>
                                    </details>
                                )}
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}

            {notInRotation.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title ended-title">Not in rotation</h3>
                    <div class="events-list" id="eventListNotInRotation">
                        {notInRotation.map(group => (
                            <div class="event-card event-ended" data-name={group.name}>
                                <div class="event-card-top">
                                    <img src={group.icon} alt={group.name} class="event-card-icon" loading="lazy" />
                                    <div>
                                        <div class="event-card-name">{group.name}</div>
                                        <div class="event-card-map">{group.maps.join(', ')}</div>
                                    </div>
                                    <span class="event-status-badge ended">Not scheduled</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}
        </Fragment>
    )}
</section>
