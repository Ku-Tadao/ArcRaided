---
import { SVG_ICONS } from '@/lib/icons';
import type { ArdbQuest } from '@/lib/types';
import { ARDB_BASE } from '@/lib/types';

interface Props {
    quests: ArdbQuest[];
    traders: string[];
}

const { quests, traders } = Astro.props;

const traderCounts = Object.fromEntries(
    traders.map(t => [t, quests.filter(q => q.trader?.name === t).length])
);
---

<section id="quests" class="content" style="display:none">
    <div class="section-header">
        <h2>Quests</h2>
        <div class="search-filter">
            <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
            <input type="text" id="questSearch" placeholder="Search quests..." />
        </div>
    </div>

    <div class="category-filters" id="traderFilters">
        <button class="cat-filter active" data-trader="all" type="button">All <span class="count">{quests.length}</span></button>
        {traders.map((t) => (
            <button class="cat-filter" data-trader={t} type="button">{t} <span class="count">{traderCounts[t]}</span></button>
        ))}
    </div>

    <div class="quests-grid" id="questList">
        {quests.map((quest) => {
            const traderIcon = quest.trader?.icon
                ? `${ARDB_BASE}${quest.trader.icon}`
                : '';

            return (
                <div
                    class="quest-card"
                    data-id={quest.id}
                    data-trader={quest.trader?.name ?? ''}
                    data-name={quest.title.toLowerCase()}
                    data-maps={quest.maps?.map(m => m.name).join(',').toLowerCase() ?? ''}
                >
                    <div class="quest-card-img" style="border-radius:50%;">
                        {traderIcon ? (
                            <img src={traderIcon} alt={quest.trader.name} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                        ) : (
                            <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;opacity:0.3"><Fragment set:html={SVG_ICONS.scroll} /></div>
                        )}
                    </div>
                    <div class="quest-card-body">
                        <div class="quest-card-title">{quest.title}</div>
                        <div class="quest-card-trader">{quest.trader?.name ?? 'Unknown'}</div>
                        {quest.maps && quest.maps.length > 0 && (
                            <div class="quest-card-desc">{quest.maps.map(m => m.name).join(', ')}</div>
                        )}
                        <div class="quest-steps">
                            <span class="quest-step">{quest.steps?.length ?? 0} steps{quest.xpReward ? ` · +${quest.xpReward} XP` : ''}</span>
                        </div>
                    </div>
                </div>
            );
        })}
    </div>

    <p class="no-results hidden" id="noQuestResults">No quests match your filters.</p>
</section>
