---
/**
 * Weekly Trials — displays weekly trials from MetaForge weekly-trials endpoint.
 */
import { SVG_ICONS } from '@/lib/icons';
import type { WeeklyTrial } from '@/lib/types';

interface Props {
    trials: WeeklyTrial[];
}

const { trials } = Astro.props;

const activeTrials = trials.filter(t => t.is_active).sort((a, b) => a.sort_order - b.sort_order);
const upcomingTrials = trials.filter(t => t.upcoming && !t.is_active).sort((a, b) => a.sort_order - b.sort_order);
const otherTrials = trials.filter(t => !t.is_active && !t.upcoming).sort((a, b) => a.sort_order - b.sort_order);
---

<section id="weekly-trials" class="content" style="display:none">
    <div class="section-header">
        <h2>Weekly Trials</h2>
        <span class="badge">{activeTrials.length} active · {upcomingTrials.length} upcoming · {trials.length} total</span>
    </div>

    {trials.length === 0 ? (
        <div class="empty-state">
            <Fragment set:html={SVG_ICONS.calendar} />
            <p>No weekly trial data available.</p>
        </div>
    ) : (
        <Fragment>
            {activeTrials.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title active-title">Active Weekly Trials</h3>
                    <div class="weekly-grid">
                        {activeTrials.map(trial => (
                            <div class="weekly-card event-active">
                                <div class="weekly-card-header">
                                    <span class="event-status-badge active">Active</span>
                                </div>
                                {trial.image_url && (
                                    <img src={trial.image_url} alt={trial.name} loading="lazy" class="weekly-card-img" />
                                )}
                                <div class="weekly-card-body">
                                    <div class="weekly-card-name">{trial.name}</div>
                                    {trial.database_links.length > 0 && (
                                        <div class="weekly-db-links">
                                            {trial.database_links.map(link => (
                                                <a href={link.url} target="_blank" rel="noopener" class="weekly-db-link">
                                                    {link.icon_url && <img src={link.icon_url} alt="" class="weekly-db-icon" />}
                                                    {link.label}
                                                </a>
                                            ))}
                                        </div>
                                    )}
                                    <div class="weekly-card-links">
                                        {trial.guide_link && (
                                            <a href={trial.guide_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                <Fragment set:html={SVG_ICONS.book} /> Guide
                                            </a>
                                        )}
                                        {trial.video_link && (
                                            <a href={trial.video_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                ▶ Video
                                            </a>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}

            {upcomingTrials.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title upcoming-title">Next Trials</h3>
                    <div class="weekly-grid">
                        {upcomingTrials.map(trial => (
                            <div class="weekly-card event-upcoming">
                                <div class="weekly-card-header">
                                    <span class="event-status-badge upcoming">Next</span>
                                </div>
                                {trial.image_url && (
                                    <img src={trial.image_url} alt={trial.name} loading="lazy" class="weekly-card-img" />
                                )}
                                <div class="weekly-card-body">
                                    <div class="weekly-card-name">{trial.name}</div>
                                    <div class="weekly-card-links">
                                        {trial.guide_link && (
                                            <a href={trial.guide_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                <Fragment set:html={SVG_ICONS.book} /> Guide
                                            </a>
                                        )}
                                        {trial.video_link && (
                                            <a href={trial.video_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                ▶ Video
                                            </a>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}

            {otherTrials.length > 0 && (
                <Fragment>
                    <h3 class="event-section-title ended-title">All Other Trials</h3>
                    <div class="weekly-grid">
                        {otherTrials.map(trial => (
                            <div class="weekly-card">
                                {trial.image_url && (
                                    <img src={trial.image_url} alt={trial.name} loading="lazy" class="weekly-card-img" />
                                )}
                                <div class="weekly-card-body">
                                    <div class="weekly-card-name">{trial.name}</div>
                                    <div class="weekly-card-links">
                                        {trial.guide_link && (
                                            <a href={trial.guide_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                <Fragment set:html={SVG_ICONS.book} /> Guide
                                            </a>
                                        )}
                                        {trial.video_link && (
                                            <a href={trial.video_link} target="_blank" rel="noopener" class="guide-link-btn">
                                                ▶ Video
                                            </a>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </Fragment>
            )}
        </Fragment>
    )}
</section>
