---
import { SVG_ICONS, getWeaponIconSVG } from '@/lib/icons';
import type { ArdbItem } from '@/lib/types';
import { ITEM_CATEGORIES, WEAPON_TYPES, ARDB_BASE } from '@/lib/types';
import { renderItemCard } from '@/lib/client/templates';

interface Props {
    items: ArdbItem[];
}

const { items } = Astro.props;

const rarities = ['common', 'uncommon', 'rare', 'epic', 'legendary'];

const catCounts = Object.fromEntries(
    ITEM_CATEGORIES.map(cat => [cat, cat === 'All' ? items.length : items.filter(i => i.category === cat).length])
);

const weapons = items.filter(i => i.category === 'Weapons');
const weaponTypeCounts = Object.fromEntries(
    WEAPON_TYPES.map(wt => [wt, weapons.filter(w => w.type.toLowerCase() === wt.toLowerCase()).length])
);
---

<section id="items" class="content" style="display:none">
    <div class="section-header">
        <h2>Items</h2>
        <div class="search-filter">
            <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
            <input type="text" id="itemSearch" placeholder="Search items..." />
        </div>
    </div>

    <div class="category-filters" id="categoryFilters">
        {ITEM_CATEGORIES.map((cat) => (
            <button
                class:list={['cat-filter', { active: cat === 'All' }]}
                data-category={cat}
                type="button"
            >
                {cat} <span class="count">{catCounts[cat]}</span>
            </button>
        ))}
    </div>

    <div class="category-filters" id="rarityFilters" style="margin-top: 0.25rem;">
        <button class="cat-filter active" data-rarity="all" type="button">All Rarities</button>
        {rarities.map((r) => (
            <button class="cat-filter" data-rarity={r} type="button">
                <span class="rarity-dot" style={`background: var(--rarity-${r})`}></span>
                {r.charAt(0).toUpperCase() + r.slice(1)}
            </button>
        ))}
    </div>

    <div class="category-filters hidden" id="weaponTypeFilters" style="margin-top: 0.25rem;">
        <button class="cat-filter active" data-weapon-type="all" type="button">All Types <span class="count">{weapons.length}</span></button>
        {WEAPON_TYPES.map((wt) => (
            <button class="cat-filter" data-weapon-type={wt.toLowerCase()} type="button">
                {wt} <span class="count">{weaponTypeCounts[wt]}</span>
            </button>
        ))}
    </div>

    <div class="items-grid" id="itemGrid">
        {items.map((item) => (
            <Fragment set:html={renderItemCard(item, 'ardb', getWeaponIconSVG)} />
        ))}
    </div>

    <p class="no-results hidden" id="noItemResults">No items match your filters.</p>
</section>
