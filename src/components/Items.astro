---
import type { ArdbItem } from '@/lib/types';
import { ITEM_CATEGORIES, ARDB_BASE } from '@/lib/types';
import { icons } from '@/lib/icons';

interface Props {
    items: ArdbItem[];
}

const { items } = Astro.props;

// Group rarities for filter buttons
const rarities = ['common', 'uncommon', 'rare', 'epic', 'legendary'];
---

<section class="section hidden" id="items" data-section="items">
    <div class="section-header">
        <h3>Items</h3>
        <span class="section-count">{items.length} items</span>
    </div>

    <!-- Search -->
    <div class="search-filter">
        <span class="search-icon" set:html={icons.search} />
        <input type="text" id="itemSearch" placeholder="Search items by name or type..." autocomplete="off" />
    </div>

    <!-- Category Filters -->
    <div class="category-filters" id="categoryFilters">
        {ITEM_CATEGORIES.map((cat) => (
            <button
                class:list={['filter-btn', { active: cat === 'All' }]}
                data-category={cat}
                type="button"
            >
                {cat}
            </button>
        ))}
    </div>

    <!-- Rarity Filters -->
    <div class="category-filters" id="rarityFilters" style="margin-top: 0.25rem;">
        <button class="filter-btn active" data-rarity="all" type="button">All Rarities</button>
        {rarities.map((r) => (
            <button class="filter-btn" data-rarity={r} type="button">
                <span class="rarity-dot" style={`background: var(--rarity-${r})`}></span>
                {r.charAt(0).toUpperCase() + r.slice(1)}
            </button>
        ))}
    </div>

    <!-- Item Grid -->
    <div class="item-grid" id="itemGrid">
        {items.map((item) => (
            <button
                class="item-card"
                data-rarity={item.rarity ?? 'common'}
                data-category={item.category}
                data-type={item.type}
                data-name={item.name.toLowerCase()}
                data-id={item.id}
                type="button"
            >
                <div class="item-card-img">
                    {item.icon ? (
                        <img
                            src={`${ARDB_BASE}${item.icon}`}
                            alt={item.name}
                            loading="lazy"
                            width="64"
                            height="64"
                        />
                    ) : (
                        <span class="item-card-placeholder" set:html={icons.package} />
                    )}
                </div>
                <div class="item-card-body">
                    <span class="item-card-name">{item.name}</span>
                    <span class="item-card-type">{item.type}</span>
                </div>
            </button>
        ))}
    </div>

    <p class="no-results hidden" id="noItemResults">No items match your filters.</p>
</section>

<style>
    .rarity-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 2px;
    }
    .item-card-placeholder {
        opacity: 0.3;
        color: var(--text-secondary);
    }
    .no-results {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-secondary);
        font-size: 0.95rem;
    }
</style>
