---
import { SVG_ICONS } from '@/lib/icons';
import type { ArdbEnemy } from '@/lib/types';
import { ARDB_BASE } from '@/lib/types';

interface Props {
    enemies: ArdbEnemy[];
}

const { enemies } = Astro.props;

function resolveImg(path: string | undefined): string {
    if (!path) return '';
    if (path.startsWith('http')) return path;
    return `${ARDB_BASE}${path}`;
}
---

<section id="enemies" class="content" style="display:none">
    <div class="section-header">
        <h2>ARC Enemies</h2>
        <div class="search-filter">
            <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
            <input type="text" id="enemySearch" placeholder="Search enemies..." />
        </div>
    </div>

    <div class="enemies-grid" id="enemyGrid">
        {enemies.map((enemy) => {
            const iconSrc = resolveImg(enemy.icon);
            const imageSrc = resolveImg(enemy.image);

            return (
                <div class="enemy-card" data-id={enemy.id} data-name={enemy.name.toLowerCase()}>
                    <div class="enemy-card-icon-wrap">
                        {imageSrc ? (
                            <img
                                src={imageSrc}
                                alt={enemy.name}
                                loading="lazy"
                                class="enemy-card-icon"
                            />
                        ) : iconSrc ? (
                            <img
                                src={iconSrc}
                                alt={enemy.name}
                                loading="lazy"
                                class="enemy-card-icon"
                            />
                        ) : (
                            <div style="opacity:0.25"><Fragment set:html={SVG_ICONS.crosshair} /></div>
                        )}
                    </div>
                    <span class="enemy-card-name">{enemy.name}</span>
                    {enemy.dropTable.length > 0 && (
                        <span class="enemy-card-drops">{enemy.dropTable.length} drops</span>
                    )}
                </div>
            );
        })}
    </div>

    <p class="no-results hidden" id="noEnemyResults">No enemies match your search.</p>
</section>
