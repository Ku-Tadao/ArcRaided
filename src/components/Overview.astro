---
import { SVG_ICONS } from '@/lib/icons';
import type { ArdbItem, ArdbEnemy, ArdbQuest } from '@/lib/types';
import { ARDB_BASE } from '@/lib/types';

interface Props {
    items: ArdbItem[];
    enemies: ArdbEnemy[];
    quests: ArdbQuest[];
    maps: string[];
    traders: string[];
}

const { items, enemies, quests, maps, traders } = Astro.props;

const weaponCount = items.filter(i => i.category === 'Weapons').length;
const materialCount = items.filter(i => i.category === 'Materials').length;
const consumableCount = items.filter(i => i.category === 'Consumables').length;

const shuffled = [...enemies].sort(() => Math.random() - 0.5);
const stripEnemies = shuffled.slice(0, Math.min(12, enemies.length));

const featured = enemies.slice(0, Math.min(6, enemies.length));

function resolveImg(path: string | undefined): string {
    if (!path) return '';
    if (path.startsWith('http')) return path;
    return `${ARDB_BASE}${path}`;
}
---

<section id="overview" class="content">
    <div class="overview-splash">
        <div class="splash-inner">
            <h2>Arc Raiders <span>Data Hub</span></h2>
            <p class="splash-sub">Explore items, enemies, quests, and traders for Arc Raiders. All data powered by community APIs.</p>

            <div class="hero-portrait-strip">
                {stripEnemies.map(e => (
                    <img
                        src={resolveImg(e.image) || resolveImg(e.icon)}
                        alt={e.name}
                        loading="lazy"
                        title={e.name}
                    />
                ))}
            </div>
        </div>
    </div>

    <div class="overview-stats-row">
        <div class="ov-stat ov-total" data-section="items">
            <div class="ov-num">{items.length}</div>
            <div class="ov-label"><Fragment set:html={SVG_ICONS.package} /> Items</div>
        </div>
        <div class="ov-stat ov-weapons" data-section="items">
            <div class="ov-num">{weaponCount}</div>
            <div class="ov-label"><Fragment set:html={SVG_ICONS.crosshair} /> Weapons</div>
        </div>
        <div class="ov-stat ov-enemies" data-section="enemies">
            <div class="ov-num">{enemies.length}</div>
            <div class="ov-label"><Fragment set:html={SVG_ICONS.target} /> Enemies</div>
        </div>
        <div class="ov-stat ov-quests" data-section="quests">
            <div class="ov-num">{quests.length}</div>
            <div class="ov-label"><Fragment set:html={SVG_ICONS.scroll} /> Quests</div>
        </div>
        <div class="ov-stat ov-maps" data-section="overview">
            <div class="ov-num">{maps.length}</div>
            <div class="ov-label"><Fragment set:html={SVG_ICONS.compass} /> Maps</div>
        </div>
    </div>

    <div class="ql-grid">
        <div class="ql-card" data-section="items">
            <div class="ql-icon ql-items"><Fragment set:html={SVG_ICONS.package} /></div>
            <div>
                <div class="ql-title">Item Database</div>
                <p class="ql-desc">{weaponCount} weapons, {materialCount} materials, {consumableCount} consumables &amp; more</p>
            </div>
        </div>
        <div class="ql-card" data-section="enemies">
            <div class="ql-icon ql-enemies"><Fragment set:html={SVG_ICONS.crosshair} /></div>
            <div>
                <div class="ql-title">ARC Enemies</div>
                <p class="ql-desc">{enemies.length} enemies with drop tables &amp; spawn maps</p>
            </div>
        </div>
        <div class="ql-card" data-section="quests">
            <div class="ql-icon ql-quests"><Fragment set:html={SVG_ICONS.scroll} /></div>
            <div>
                <div class="ql-title">Quests</div>
                <p class="ql-desc">{quests.length} quests from {traders.length} traders across {maps.length} maps</p>
            </div>
        </div>
    </div>

    <div class="featured-section">
        <h3>Featured Enemies</h3>
        <div class="featured-heroes-row">
            {featured.map(e => (
                <div class="featured-hero" data-enemy-id={e.id}>
                    <img src={resolveImg(e.image) || resolveImg(e.icon)} alt={e.name} loading="lazy" />
                    <div class="fh-info">
                        <div class="fh-name">{e.name}</div>
                        <div class="fh-role" style="color:var(--rarity-epic)">{e.dropTable.length} drops</div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
