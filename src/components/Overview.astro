---
import type { ArcRaidedData } from '@/lib/types';
import { icons } from '@/lib/icons';

interface Props {
    data: ArcRaidedData;
}

const { data } = Astro.props;
const { items, enemies, quests, maps, traders, buildInfo } = data;

// Count items by category
const weaponCount = items.filter(i => (i.category === 'Weapons')).length;
const materialCount = items.filter(i => (i.category === 'Materials')).length;
const consumableCount = items.filter(i => (i.category === 'Consumables')).length;
---

<section class="section" id="overview" data-section="overview">
    <!-- Splash -->
    <div class="overview-splash">
        <div class="overview-splash-top-bar"></div>
        <div class="overview-splash-content">
            <h2>ArcRaided</h2>
            <p>Your complete Arc Raiders data hub. Browse items, enemies, quests, and traders — all in one place.</p>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
            <span class="stat-value">{buildInfo.itemCount}</span>
            <span class="stat-label">Items</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">{buildInfo.enemyCount}</span>
            <span class="stat-label">ARC Enemies</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">{buildInfo.questCount}</span>
            <span class="stat-label">Quests</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">{buildInfo.mapCount}</span>
            <span class="stat-label">Maps</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">{buildInfo.traderCount}</span>
            <span class="stat-label">Traders</span>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="quick-links">
        <button class="quick-link-card" data-goto="items">
            <div class="quick-link-icon" style="color: var(--rarity-rare);" set:html={icons.package} />
            <div class="quick-link-info">
                <strong>Items</strong>
                <span>{weaponCount} weapons, {materialCount} materials, {consumableCount} consumables & more</span>
            </div>
            <span class="quick-link-arrow" set:html={icons.chevronRight} />
        </button>
        <button class="quick-link-card" data-goto="enemies">
            <div class="quick-link-icon" style="color: var(--rarity-epic);" set:html={icons.crosshair} />
            <div class="quick-link-info">
                <strong>ARC Enemies</strong>
                <span>{enemies.length} enemies with drop tables & spawn maps</span>
            </div>
            <span class="quick-link-arrow" set:html={icons.chevronRight} />
        </button>
        <button class="quick-link-card" data-goto="quests">
            <div class="quick-link-icon" style="color: var(--rarity-legendary);" set:html={icons.scroll} />
            <div class="quick-link-info">
                <strong>Quests</strong>
                <span>{quests.length} quests from {traders.length} traders across {maps.length} maps</span>
            </div>
            <span class="quick-link-arrow" set:html={icons.chevronRight} />
        </button>
    </div>

    <!-- Map list -->
    <div class="section-header">
        <h3>Maps</h3>
    </div>
    <div class="stats-row" style="grid-template-columns: repeat(auto-fit, minmax(180px,1fr));">
        {maps.map(m => (
            <div class="stat-card">
                <span class="stat-label" set:html={icons.compass} />
                <span class="stat-value" style="font-size: 1rem;">{m}</span>
            </div>
        ))}
    </div>

    <!-- Trader list -->
    <div class="section-header">
        <h3>Traders</h3>
    </div>
    <div class="stats-row" style="grid-template-columns: repeat(auto-fit, minmax(140px,1fr));">
        {traders.map(t => (
            <div class="stat-card">
                <span class="stat-label" set:html={icons.users} />
                <span class="stat-value" style="font-size: 1rem;">{t}</span>
            </div>
        ))}
    </div>

    <p class="footer-disclaimer" style="text-align: center; margin-top: 2rem;">
        Last updated: {new Date(buildInfo.generatedAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
    </p>
</section>
