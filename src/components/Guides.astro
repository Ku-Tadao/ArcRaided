---
import { SVG_ICONS } from '@/lib/icons';
import type { MetaForgeQuest } from '@/lib/types';

interface Props {
    quests: MetaForgeQuest[];
}

const { quests } = Astro.props;

// Filter quests that have guide_links
const guidedQuests = quests.filter(q => q.guide_links && q.guide_links.length > 0);
---

<section id="guides" class="content" data-source-only="metaforge" style="display:none">
    <div class="section-header">
        <h2>Guides</h2>
        <div class="search-filter">
            <span class="search-icon"><Fragment set:html={SVG_ICONS.search} /></span>
            <input type="text" id="guideSearch" placeholder="Search guides..." />
        </div>
    </div>

    {guidedQuests.length === 0 ? (
        <div class="empty-state">
            <Fragment set:html={SVG_ICONS.book} />
            <p>No guide data available yet. Guides are sourced from MetaForge quest data.</p>
        </div>
    ) : (
        <div class="guides-grid" id="guideGrid">
            {guidedQuests.map((quest) => (
                <div class="guide-card" data-name={quest.name.toLowerCase()}>
                    <div class="guide-card-header">
                        {quest.image && (
                            <img src={quest.image} alt={quest.name} loading="lazy" class="guide-card-img" />
                        )}
                        <div class="guide-card-info">
                            <div class="guide-card-name">{quest.name}</div>
                            <div class="guide-card-trader">{quest.trader_name}</div>
                        </div>
                    </div>
                    {quest.objectives && quest.objectives.length > 0 && (
                        <div class="guide-objectives">
                            {quest.objectives.slice(0, 3).map((obj: string) => (
                                <div class="guide-objective">
                                    <span class="guide-obj-bullet">▸</span>
                                    <span>{obj}</span>
                                </div>
                            ))}
                            {quest.objectives.length > 3 && (
                                <span class="muted" style="font-size:.72rem">+{quest.objectives.length - 3} more objectives</span>
                            )}
                        </div>
                    )}
                    <div class="guide-links">
                        {quest.guide_links.map((link: { url: string; label: string }) => (
                            <a href={link.url} target="_blank" rel="noopener noreferrer" class="guide-link-btn">
                                <Fragment set:html={SVG_ICONS.book} />
                                {link.label}
                            </a>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    )}

    <p class="no-results hidden" id="noGuideResults">No guides match your search.</p>
</section>
